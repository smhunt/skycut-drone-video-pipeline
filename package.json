{
  "name": "skycut",
  "version": "0.2.0",
  "description": "Local-first MCP server that turns raw drone footage into polished marketing cuts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skycut": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "web": "node web/server.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "better-sqlite3": "^12.2.0",
    "execa": "^9.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
